PORT=4000

# Random hex string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=2312312

# Where the client lives (used for CORS + post-login redirect)
CLIENT_ORIGIN=http://localhost:5173

# Google service-account JSON key. Create one in Google Cloud Console -> IAM & Admin -> Service Accounts.
# Share the three resources below (root folder, users sheet, projects sheet) with this service account email as Editor.
#
# LOCAL: point this at the JSON file path you downloaded.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials/service-account.json
#
# VERCEL: instead of a file, paste the entire JSON contents into this env var (keep newlines in private_key escaped as \n).
# When set, this takes precedence over GOOGLE_SERVICE_ACCOUNT_KEY_FILE.
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}

# Drive folder that holds everything (Users sheet, Projects sheet, every per-project subfolder).
# Create a folder named "MyApp" in any Drive (yours or a shared drive), share it with the service account as Editor,
# then paste the folder id here.
APP_ROOT_FOLDER_ID=1B9kLp1XuFIE_GuqwWOfMcVpvG17Fv7nt

# Global Users sheet (login + registration table). Create a Google Sheet, add a tab "Users",
# share it with the service account as Editor, paste the spreadsheet id here.
USERS_SHEET_ID=1pcdRP612CfuAwZpbnZmfruKDdKBYm7qkeGm_NdszpmU

# Global Projects sheet (project catalogue). Create a Google Sheet, add a tab "Projects",
# share it with the service account as Editor, paste the spreadsheet id here.
PROJECTS_SHEET_ID=

# --- Optional: persistent storage for sessions / OAuth owner tokens ---------
# Leave unset for local dev (server/data/store.json is used).
# On Vercel, provision a Vercel KV (or any Upstash Redis) integration. The integration
# auto-injects KV_REST_API_URL + KV_REST_API_TOKEN. UPSTASH_REDIS_REST_* are also accepted.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Optional: owner Google OAuth (only needed if your install uses /api/auth/google) -
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://<your-vercel-domain>/api/auth/callback
