{
  "name": "drive-projects",
  "private": true,
  "version": "0.1.0",
  "description": "Google Drive-based project management MVP — OAuth user flow, Drive + Sheets + Docs.",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "start:server": "npm start --workspace server",
    "build:client": "npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
